# Gere com: openssl rand -hex 32 (ou qualquer string longa aleatoria)
SECRET_KEY=change-me
ACCESS_TOKEN_EXPIRE_MINUTES=720
ADMIN_USERNAME=admin
# Usada apenas na primeira inicializacao para criar o usuario admin
ADMIN_PASSWORD=change-me
DATABASE_URL=sqlite:///./mulherviva.db
CORS_ORIGINS=http://localhost:5173
# Token de longa duracao do Instagram (conta Business/Creator)
IG_ACCESS_TOKEN=
IG_AUTO_SYNC=false
MIN_BOOKING_LEAD_HOURS=2
# Politicas de agendamento (tambem editaveis no painel admin)
BUFFER_MINUTES=0
CANCELLATION_WINDOW_HOURS=12
MAX_BOOKING_ADVANCE_DAYS=60

# ---- E-mail / notificacoes ----
# Habilita o envio de e-mails (confirmacao, status). Sem isto, nada e enviado.
NOTIFICATIONS_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=true
EMAIL_FROM=Mulher Viva <no-reply@mulherviva.com.br>
# URL publica do site (usada em links de e-mail)
PUBLIC_BASE_URL=http://localhost:5173
CLINIC_NAME=Mulher Viva — Dra. Luciana Lopes
